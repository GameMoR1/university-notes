# ============================================
# УНИВЕРСИТЕТСКАЯ СИСТЕМА УЧЕБНЫХ ЗАМЕТОК
# Конфигурация окружения
# ============================================

# Режим тестирования (true = SQLite, false = PostgreSQL)
TEST=true

# --- PostgreSQL (используется если TEST=false) ---
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=notes_password
POSTGRES_DB=university_notes
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- SQLite (используется если TEST=true) ---
SQLITE_DB_PATH=./data/university_notes.db

# --- Backend ---
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# --- Первый администратор (создаётся при первом запуске) ---
ADMIN_EMAIL=admin@university.ru
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Администратор

# --- Debug ---
DEBUG=true
LOG_LEVEL=INFO
