# ============================================
# УНИВЕРСИТЕТСКАЯ СИСТЕМА УЧЕБНЫХ ЗАМЕТОК
# Конфигурация окружения
# ============================================
# Скопируйте в .env и отредактируйте под свой ПК:
#   cp .env.example .env
# Затем запустите:
#   docker compose -f docker-compose-prod.yaml up -d

# --- MinIO (S3-хранилище файлов) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=usuz-files
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001

# --- PostgreSQL ---
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=notes_password
POSTGRES_DB=university_notes
# POSTGRES_PORT=5432

# --- Backend ---
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALLOWED_ORIGINS=http://localhost:7009
ADMIN_EMAIL=admin@university.ru
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Администратор
LOG_LEVEL=INFO

# --- Порты хоста (можно менять если порты заняты) ---
# BACKEND_PORT=8000
# FRONTEND_PORT=7009
