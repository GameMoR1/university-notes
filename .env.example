# ============================================
# УНИВЕРСИТЕТСКАЯ СИСТЕМА УЧЕБНЫХ ЗАМЕТОК
# Конфигурация
# ============================================
# Скопируйте в .env и заполните свои значения.
# ВАЖНО: Никому не передавайте этот файл!
# Он содержит пароли и ключи доступа к БД, MinIO и JWT.

# --- PostgreSQL ---
# ОБЯЗАТЕЛЬНО сменить пароль!
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=notes_password
POSTGRES_DB=university_notes
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- MinIO (S3-хранилище файлов) ---
# ОБЯЗАТЕЛЬНО сменить на сложные уникальные значения!
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=usuz-files

# --- JWT-секрет (ОБЯЗАТЕЛЬНО сменить!) ---
# Минимум 32 символа, любой сложности.
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars

# --- CORS ---
# Домен, с которого будут ходить запросы (фронтенд).
ALLOWED_ORIGINS=http://localhost:7009

# --- Первый администратор (создаётся при первом запуске) ---
# ОБЯЗАТЕЛЬНО сменить email и пароль!
ADMIN_EMAIL=admin@university.ru
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Администратор

# --- Логирование ---
LOG_LEVEL=INFO
